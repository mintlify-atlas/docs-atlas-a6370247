  "keyFeatures": [
    "User-mode isolation using Windows Projected File System (ProjFS)",
    "Registry virtualization through hive cloning and redirection",
    "System call interception via DynamoRIO without kernel hooks",
    "Behavior-based malware detection using Lua and Python rules",
    "Comprehensive monitoring of filesystem, registry, processes, and network operations",
    "JSON-based behavior reports for analysis",
    "Support for both x86 and x64 executables",
    "Community-driven detection rules"
  ],
  "publicApiSurface": [
    "DrSemu.exe --target <file_path>",
    "DrSemu.exe --target <directory>",
    "DrSemu.exe --target <file_path> --cmd_line <arguments>",
    "DrSemu.exe --target <file_path> --time_limit <seconds>",
    "Lua rule: check(report_directory)",
    "Python rule: check(report_directory)",
    "utils.get_first_process_json(report_directory)",
    "utils.get_first_static(report_directory)",
    "utils.get_json_pid(report_directory, pid)",
    "dr_semu_utils.get_starter_details(report_directory)",
    "dr_semu_utils.get_json_from_file(file_path)"
  ]
